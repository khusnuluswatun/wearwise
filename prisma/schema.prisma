generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password      String
  phone         String
  address       String
  rewardPoints  Int      @default(0)
  role          String   @default("user") // "user" or "partner"
  createdAt     DateTime @default(now())

  partner           Partner?
  scans             Scan[]
  items             Item[]
  transactions      Transaction[]
  rewards           Reward[]
  saleMade          SaleTransaction[] @relation("SellerTransactions")
  saleBought        SaleTransaction[] @relation("BuyerTransactions")

  @@map("users")
}

model Scan {
  id               String   @id @default(uuid())
  userId           String
  imageUrl         String
  aiDescription    String?
  aiRecommendation String?
  userChoice       String?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("scans")
}

model Partner {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  type        String
  name        String
  description String?
  address     String?
  phone       String?
  latitude    Float?
  longitude   Float?

  transactions Transaction[]

  @@map("partners")
}

model Item {
  id          String   @id @default(uuid())
  userId      String
  scanId      String
  title       String
  description String?
  price       Int
  status      String   @default("available")

  user         User             @relation(fields: [userId], references: [id])
  saleTransactions SaleTransaction[]

  @@map("items")
}

model SaleTransaction {
  id              String   @id @default(uuid())
  itemId          String
  sellerId        String
  buyerId         String
  proofImageUrl   String
  status          String   @default("pending_verification") // pending_verification | verified | rejected
  pointsAwarded   Int      @default(0)
  createdAt       DateTime @default(now())
  verifiedAt      DateTime?

  item    Item @relation(fields: [itemId], references: [id])
  seller  User @relation("SellerTransactions", fields: [sellerId], references: [id])
  buyer   User @relation("BuyerTransactions", fields: [buyerId], references: [id])

  @@map("sale_transactions")
}

model Transaction {
  id              String   @id @default(uuid())
  userId          String
  partnerId       String?
  itemId          String?
  scanId          String?
  type            String
  status          String   @default("pending")
  deliveryMethod  String?  // "drop_off" or "pickup"
  pickupAddress   String?
  pickupTime      String?
  startDate       DateTime?
  endDate         DateTime?
  price           Int?
  buyerConfirmed  Boolean  @default(false)
  sellerConfirmed Boolean  @default(false)
  paymentMethod   String?
  notes           String?
  createdAt       DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  partner Partner? @relation(fields: [partnerId], references: [id])

  @@map("transactions")
}

model Reward {
  id        String   @id @default(uuid())
  userId    String
  type      String
  points    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("rewards")
}